# ============================================
# KaiyanTool 环境变量配置
# ============================================
# 请复制此文件为 .env 并填入真实值
# ============================================

# ============================================
# 数据库配置
# ============================================
POSTGRES_USER=kaiyan_user
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=kaiyan_platform

# ============================================
# JWT 安全配置
# ============================================
# 建议使用随机生成的32位以上字符串
# 可以使用以下命令生成:
# openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-characters
JWT_EXPIRES_IN=7d

# ============================================
# 服务器配置
# ============================================
NODE_ENV=production
PORT=3001

# ============================================
# AI Provider API Keys
# ============================================
# OpenAI (GPT-4/ChatGPT)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-organization-id

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# 智谱AI (GLM)
ZHIPU_API_KEY=your-zhipu-api-key

# Google (Gemini)
GOOGLE_API_KEY=your-google-api-key

# 阿里云通义千问
DASHSCOPE_API_KEY=your-dashscope-api-key

# ============================================
# 腾讯云 OSS 对象存储
# ============================================
# 用于存储生成的图片、视频等素材
OSS_ACCESS_KEY_ID=your-tencent-cloud-secret-id
OSS_ACCESS_KEY_SECRET=your-tencent-cloud-secret-key
OSS_REGION=ap-guangzhou
OSS_BUCKET=your-bucket-name
# OSS 访问域名 (可选，自定义域名)
# OSS_ENDPOINT=cos.ap-guangzhou.myqcloud.com

# ============================================
# CORS 跨域配置
# ============================================
# 前端域名，用于允许跨域请求
CORS_ORIGIN=http://localhost:3000
# 生产环境改为你的域名
# CORS_ORIGIN=https://www.yourdomain.com

# ============================================
# 前端环境变量
# ============================================
# API 地址 (生产环境)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 生产环境:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_APP_URL=https://www.yourdomain.com

# ============================================
# Sentry 错误监控 (可选)
# ============================================
# 访问 https://sentry.io 创建项目获取 DSN
SENTRY_DSN=your-sentry-dsn-url

# ============================================
# 日志级别
# ============================================
LOG_LEVEL=info
# 可选: debug, info, warn, error

# ============================================
# Redis 配置 (可选，使用 docker-compose 时自动配置)
# ============================================
# REDIS_URL=redis://redis:6379

# ============================================
# 文件上传配置
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
