# ========================================
# 生产环境配置
# ========================================

# 基础配置
NODE_ENV=production
PORT=3001
API_URL=https://api.kaiyantool.com
WEB_URL=https://kaiyantool.com

# 数据库配置
DATABASE_URL="postgresql://kaiyan_user:STRONG_PASSWORD_HERE@postgres:5432/kaiyan_platform?sslmode=require"

# Redis配置
REDIS_URL="redis://redis:6379"
REDIS_PASSWORD=STRONG_PASSWORD_HERE

# 加密配置
ENCRYPTION_KEY=32-char-encryption-key-for-production
JWT_SECRET=64-char-jwt-secret-key-for-production-use-random-string

# AI提供商配置
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
ZHIPU_AI_API_KEY=your-zhipu-ai-api-key

# 文件存储
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# 会话配置
SESSION_SECRET=128-char-session-secret-key-for-production
SESSION_TTL=604800

# CORS配置
CORS_ORIGIN=https://kaiyantool.com

# APM监控
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
OTLP_ENDPOINT=http://jaeger:4318/v1/traces

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# 性能配置
REQUEST_TIMEOUT=30000
RESPONSE_TIMEOUT=60000
MAX_CONCURRENT_REQUESTS=100

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 文件清理
CLEANUP_INTERVAL=86400000
CLEANUP_AGE_DAYS=30

# 健康检查
HEALTH_CHECK_INTERVAL=30000

# CDN配置
CDN_ENABLED=true
CDN_URL=https://cdn.kaiyantool.com

# 邮件配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@kaiyantool.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Kaiyan Tool <notifications@kaiyantool.com>

# 通知配置
NOTIFICATION_ENABLED=true
NOTIFICATION_CHANNELS=email,slack

# 备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# 功能开关
FEATURE_ANALYTICS=true
FEATURE_AUDIT_LOG=true
FEATURE_API_RATE_LIMIT=true
FEATURE_AI_CACHING=true
