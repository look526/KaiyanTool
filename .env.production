# Database
POSTGRES_USER=kaiyan_user
POSTGRES_PASSWORD=your-secure-password-here-change-this
POSTGRES_DB=kaiyan_platform

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# API Configuration
NODE_ENV=production
PORT=3001

# AI Provider API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ZHIPU_API_KEY=your-zhipu-key
GOOGLE_API_KEY=your-google-key
ANTSK_API_KEY=your-antsk-key

# OSS Storage ( Tencent Cloud COS )
OSS_ACCESS_KEY_ID=your-oss-access-key
OSS_ACCESS_KEY_SECRET=your-oss-secret-key
OSS_REGION=ap-guangzhou
OSS_BUCKET=your-bucket-name

# Sentry Monitoring
SENTRY_DSN=your-sentry-dsn

# CORS Origin
CORS_ORIGIN=https://www.yourdomain.com

# Frontend URL
NEXT_PUBLIC_APP_URL=https://www.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
