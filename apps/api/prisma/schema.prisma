generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AIProvider {
  id              String            @id @db.Uuid
  user_id         String            @db.Uuid
  type            String
  api_key         String
  base_url        String?
  enabled         Boolean           @default(true)
  created_at      DateTime          @default(now())
  updated_at      DateTime
  User            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  AIProviderModel AIProviderModel[]

  @@index([user_id])
}

model AIProviderModel {
  id                   String     @id @db.Uuid
  ai_provider_id       String     @db.Uuid
  name                 String
  model_id             String?
  description          String?
  capabilities         String[]
  created_at           DateTime   @default(now())
  updated_at           DateTime
  types                String[]
  is_assistant_default Boolean    @default(false)
  AIProvider           AIProvider @relation(fields: [ai_provider_id], references: [id], onDelete: Cascade)

  @@index([ai_provider_id])
  @@index([model_id])
}

model AgentTask {
  id            String     @id @db.Uuid
  project_id    String     @db.Uuid
  content_id    String?    @db.Uuid
  agent_type    AgentType
  input         Json
  output        Json?
  ai_model      String?
  status        TaskStatus @default(pending)
  error_message String?
  created_at    DateTime   @default(now())
  started_at    DateTime?
  completed_at  DateTime?
  Content       Content?   @relation(fields: [content_id], references: [id])
  Project       Project    @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([content_id])
  @@index([project_id])
  @@index([status])
}

model AlertRecord {
  id              String    @id @db.Uuid
  rule_id         String    @db.Uuid
  severity        String
  message         String
  channels        String[]  @default([])
  acknowledged    Boolean   @default(false)
  acknowledged_at DateTime?
  created_at      DateTime  @default(now())

  @@index([created_at])
  @@index([rule_id])
  @@index([severity])
}

model AlertRule {
  id         String   @id @db.Uuid
  name       String
  metric     String
  condition  String
  threshold  Float
  severity   String
  enabled    Boolean  @default(true)
  channels   String[] @default([])
  created_at DateTime @default(now())
  updated_at DateTime

  @@index([enabled])
  @@index([metric])
}

model Asset {
  id         String   @id @db.Uuid
  type       String
  url        String
  project_id String   @db.Uuid
  metadata   Json?    @default("{}")
  created_at DateTime @default(now())
  updated_at DateTime
  category   String?  @default("general")
  source     String?  @default("upload")

  @@index([category])
  @@index([project_id])
  @@index([source])
  @@index([type])
}

model AuditLog {
  id            String   @id @db.Uuid
  user_id       String?  @db.Uuid
  action        String
  resource      String
  resource_id   String?
  metadata      Json?
  ip_address    String?
  user_agent    String?
  success       Boolean  @default(true)
  error_message String?
  created_at    DateTime @default(now())

  @@index([action])
  @@index([created_at])
  @@index([resource_id])
  @@index([resource])
  @@index([user_id])
}

model Backup {
  id          String   @id @db.Uuid
  project_id  String   @db.Uuid
  backup_id   String   @unique
  description String?
  size        BigInt?
  created_by  String   @db.Uuid
  created_at  DateTime @default(now())

  @@index([created_at])
  @@index([project_id])
}

model BackupSchedule {
  id             String    @id @db.Uuid
  project_id     String    @db.Uuid
  frequency      String
  time           String
  include_assets Boolean   @default(true)
  retention_days Int       @default(30)
  enabled        Boolean   @default(true)
  last_run       DateTime?
  next_run       DateTime?
  created_by     String    @db.Uuid
  created_at     DateTime  @default(now())
  updated_at     DateTime

  @@index([enabled])
  @@index([project_id])
}

model Chapter {
  id       String @id @db.Uuid
  novel_id String @db.Uuid
  title    String
  content  String
  order    Int    @default(0)
  Novel    Novel  @relation(fields: [novel_id], references: [id], onDelete: Cascade)

  @@index([novel_id])
  @@index([order])
}

model Character {
  id               String     @id @db.Uuid
  project_id       String     @db.Uuid
  name             String
  age              Int?
  gender           String?
  appearance       String
  reference_images String[]   @default([])
  created_at       DateTime   @default(now())
  updated_at       DateTime
  Project          Project    @relation(fields: [project_id], references: [id], onDelete: Cascade)
  Shot             Shot[]
  Wardrobe         Wardrobe[]

  @@index([project_id])
}

model Item {
  id          String   @id @db.Uuid
  project_id  String   @db.Uuid
  name        String
  type        String?
  image       String?
  description String?
  prompt      String?
  created_at  DateTime @default(now())
  updated_at  DateTime
  Project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
}

model ChatSession {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  project_id String?  @db.Uuid
  title      String?
  created_at DateTime @default(now())
  updated_at DateTime
  messages   Json     @default("[]")
  metadata   Json?    @default("{}")
  Project    Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([user_id])
}

model ConfigurationHistory {
  id             String   @id @db.Uuid
  user_id        String   @db.Uuid
  change_type    String
  change_details Json
  previous_value Json?
  new_value      Json
  created_at     DateTime @default(now())

  @@index([user_id, created_at])
  @@index([user_id])
}

model Content {
  id              String      @id @db.Uuid
  project_id      String      @db.Uuid
  type            ContentType
  raw_text        String
  structured_data Json?
  created_at      DateTime    @default(now())
  updated_at      DateTime
  AgentTask       AgentTask[]
  Project         Project     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  Outline         Outline[]
  Storyline       Storyline[]
}

model Document {
  id         String   @id @db.Uuid
  project_id String   @db.Uuid
  title      String
  content    String
  type       String   @default("general")
  status     String   @default("draft")
  created_at DateTime @default(now())
  updated_at DateTime
  Project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([status])
  @@index([type])
}

model Metrics {
  id        String   @id @db.Uuid
  name      String
  value     Float
  unit      String?
  timestamp DateTime @default(now())

  @@index([name])
  @@index([timestamp])
}

model MigrationLog {
  id        String   @id @db.Uuid
  source    String
  user_id   String   @db.Uuid
  result    Json
  timestamp DateTime @default(now())
  status    String   @default("pending")

  @@index([source])
  @@index([timestamp])
  @@index([user_id])
}

model ModelParameters {
  id           String      @id @db.Uuid
  user_id      String      @db.Uuid
  content_type ContentType
  parameters   Json        @default("{}")
  created_at   DateTime    @default(now())
  updated_at   DateTime
  User         User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, content_type])
  @@index([user_id, content_type])
}

model NineGridPanel {
  id         String   @id @db.Uuid
  shot_id    String   @db.Uuid
  position   Int
  prompt     String
  image_url  String?
  created_at DateTime @default(now())
  Shot       Shot     @relation(fields: [shot_id], references: [id], onDelete: Cascade)

  @@index([shot_id])
  @@index([shot_id, position])
}

model Novel {
  id         String    @id @db.Uuid
  project_id String    @db.Uuid
  title      String
  content    String
  created_at DateTime  @default(now())
  updated_at DateTime
  Chapter    Chapter[]
  Project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
}

model Outline {
  id            String     @id @db.Uuid
  project_id    String     @db.Uuid
  content_id    String?    @db.Uuid
  storyline_id  String?    @db.Uuid
  episodes      Json       @default("[]")
  agent_task_id String?    @db.Uuid
  created_at    DateTime   @default(now())
  updated_at    DateTime
  Content       Content?   @relation(fields: [content_id], references: [id])
  Project       Project    @relation(fields: [project_id], references: [id], onDelete: Cascade)
  Storyline     Storyline? @relation(fields: [storyline_id], references: [id])

  @@index([content_id])
  @@index([project_id])
  @@index([storyline_id])
}

model Plugin {
  id            String   @id @db.Uuid
  name          String   @unique
  version       String
  description   String?
  entry_point   String
  permissions   String[] @default([])
  settings      Json?    @default("{}")
  manifest      Json
  is_public     Boolean  @default(false)
  status        String   @default("pending")
  installations Int      @default(0)
  created_by    String   @db.Uuid
  created_at    DateTime @default(now())
  updated_at    DateTime

  @@index([is_public])
  @@index([status])
}

model Project {
  id             String           @id @db.Uuid
  owner_id       String           @db.Uuid
  name           String
  description    String?
  type           ProjectType      @default(script)
  status         String           @default("draft")
  settings       Json             @default("{}")
  thumbnail_url  String?
  created_at     DateTime         @default(now())
  updated_at     DateTime
  AgentTask      AgentTask[]
  Character      Character[]
  ChatSession    ChatSession[]
  Content        Content[]
  Document       Document[]
  Episode        Episode[]
  Item             Item[]
  Novel          Novel[]
  Outline        Outline[]
  User             User              @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  ProjectMember    ProjectMember[]
  PromptTemplate   PromptTemplate[]
  Scene            Scene[]
  Script           Script[]
  Shot             Shot[]
  Storyline        Storyline[]
  Video            Video[]
  VideoMergeTask   VideoMergeTask[]
  AudioTrack       AudioTrack[]
  Subtitle         Subtitle[]
  TimelineProject  TimelineProject[]
  VoiceProfile     VoiceProfile[]
  ProductionTask   ProductionTask[]
}

model ProjectMember {
  project_id String     @db.Uuid
  user_id    String     @db.Uuid
  role       MemberRole @default(viewer)
  joined_at  DateTime   @default(now())
  Project    Project    @relation(fields: [project_id], references: [id], onDelete: Cascade)
  User       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([project_id, user_id])
}

model ProjectPlugin {
  id           String   @id @db.Uuid
  plugin_id    String   @db.Uuid
  project_id   String   @db.Uuid
  installed_by String   @db.Uuid
  settings     Json     @default("{}")
  status       String   @default("active")
  created_at   DateTime @default(now())
  updated_at   DateTime

  @@unique([plugin_id, project_id])
  @@index([project_id])
}

model ProjectTemplate {
  id          String   @id @db.Uuid
  name        String
  description String?
  category    String
  config      Json     @default("{}")
  is_public   Boolean  @default(false)
  usage_count Int      @default(0)
  created_by  String   @db.Uuid
  created_at  DateTime @default(now())
  updated_at  DateTime

  @@index([category])
  @@index([created_by])
}

model ProjectVersion {
  id          String   @id @db.Uuid
  project_id  String   @db.Uuid
  name        String?
  description String?
  tags        String[] @default([])
  snapshot    Json
  parent_id   String?  @db.Uuid
  version     Int      @default(1)
  created_by  String   @db.Uuid
  created_at  DateTime @default(now())

  @@index([created_by])
  @@index([parent_id])
  @@index([project_id])
}

model PromptTemplate {
  id            String   @id @db.Uuid
  user_id       String?  @db.Uuid
  project_id    String?  @db.Uuid
  code          String   @unique
  name          String
  type          String   @default("general")
  category      String?
  default_value String
  custom_value  String?
  parent_code   String?
  description   String?
  variables     Json     @default("[]")
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime
  Project       Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  User          User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([project_id])
  @@index([type])
  @@index([user_id])
}

model QualityReport {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  type       String
  target_id  String
  score      String
  metadata   Json?    @default("{}")
  created_at DateTime @default(now())

  @@index([target_id])
  @@index([type])
  @@index([user_id])
}

model RenderTask {
  id           String    @id @db.Uuid
  type         String
  status       String    @default("pending")
  params       Json      @default("{}")
  project_id   String    @db.Uuid
  priority     Int       @default(5)
  progress     Float     @default(0)
  error        String?
  logs         Json?     @default("[]")
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime

  @@index([project_id])
  @@index([status])
  @@index([type])
}

model Episode {
  id             String   @id @db.Uuid
  project_id     String   @db.Uuid
  title          String
  episode_number Int      @default(1)
  description    String?
  script_id      String?  @db.Uuid
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  Project   Project     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  Script    Script?     @relation(fields: [script_id], references: [id])
  Scene     Scene[]
  Shot      Shot[]
  ShotDraft ShotDraft[]

  @@unique([project_id, episode_number])
  @@index([project_id])
}

model Scene {
  id               String   @id @db.Uuid
  episode_id       String   @db.Uuid
  location         String
  time             String
  description      String?
  scene_order      Int      @default(0)
  status           String   @default("pending")
  reference_images String[] @default([])
  created_at       DateTime @default(now())
  updated_at       DateTime

  Episode   Episode  @relation(fields: [episode_id], references: [id], onDelete: Cascade)
  Shot      Shot[]
  Project   Project? @relation(fields: [project_id], references: [id])
  project_id String? @db.Uuid
  Script    Script?  @relation(fields: [script_id], references: [id])
  script_id String?  @db.Uuid

  @@index([episode_id])
  @@index([episode_id, scene_order])
}

model SceneConcept {
  id               String   @id @db.Uuid
  project_id       String   @db.Uuid
  name             String
  description      String?
  location         String
  time_of_day      String?
  atmosphere       String?
  reference_images String[] @default([])
  ai_prompt        String?
  created_at       DateTime @default(now())
  updated_at       DateTime

  @@index([project_id])
}

model Script {
  id         String    @id @db.Uuid
  project_id String    @db.Uuid
  title      String
  content    String
  created_at DateTime  @default(now())
  updated_at DateTime
  Episode    Episode[]
  Scene      Scene[]
  Project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
}

model ScriptAnalysis {
  id         String   @id @db.Uuid
  project_id String   @db.Uuid
  content    String
  summary    String?
  themes     String[] @default([])
  characters Json     @default("[]")
  plotPoints Json     @default("[]")
  sentiment  String?
  created_at DateTime @default(now())
  updated_at DateTime

  @@index([project_id])
}

model Session {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  User       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
}

model Shot {
  id              String            @id @db.Uuid
  project_id      String            @db.Uuid
  episode_id      String            @db.Uuid
  scene_id        String?           @db.Uuid
  character_id    String?           @db.Uuid
  chapter_number  Int?
  episode_number  Int?
  segment_id      Int?
  cell_id         Int?
  action_summary  String
  camera_movement String?
  start_prompt    String?
  end_prompt      String?
  start_image_url String?
  end_image_url   String?
  video_url       String?
  duration        Int               @default(8)
  aspect_ratio    String            @default("16:9")
  resolution      String            @default("1080p")
  model           String?
  status          String            @default("pending")
  visual_style    String?
  audio_url       String?
  lip_sync_url    String?
  subtitle_text   String?
  audio_duration  Int?
  nine_grid_image_url String?
  nine_grid_created_at DateTime?
  created_at      DateTime          @default(now())
  updated_at      DateTime
  Episode         Episode           @relation(fields: [episode_id], references: [id], onDelete: Cascade)
  NineGridPanel   NineGridPanel[]
  Character       Character?        @relation(fields: [character_id], references: [id])
  Project         Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  Scene           Scene?            @relation(fields: [scene_id], references: [id])
  ShotAlternative ShotAlternative[]
  Video           Video?
  ShotDraft       ShotDraft[]

  @@index([character_id])
  @@index([episode_id])
  @@index([project_id])
  @@index([scene_id])
  @@index([episode_id, status])
}

model Storyline {
  id            String    @id @db.Uuid
  project_id    String    @db.Uuid
  content_id    String?   @db.Uuid
  story         String
  ai_model      String?
  agent_task_id String?   @db.Uuid
  created_at    DateTime  @default(now())
  Outline       Outline[]
  Content       Content?  @relation(fields: [content_id], references: [id])
  Project       Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([content_id])
  @@index([project_id])
}

model TutorialProgress {
  id               String    @id @db.Uuid
  tutorial_id      String    @db.Uuid
  user_id          String    @db.Uuid
  progress         Float     @default(0)
  completed        Boolean   @default(false)
  watched_duration Int       @default(0)
  last_watched_at  DateTime  @default(now())
  completed_at     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime

  @@unique([tutorial_id, user_id])
  @@index([user_id])
}

model TutorialRating {
  id          String   @id @db.Uuid
  tutorial_id String   @db.Uuid
  user_id     String   @db.Uuid
  rating      Int
  comment     String?
  created_at  DateTime @default(now())

  @@unique([tutorial_id, user_id])
  @@index([tutorial_id])
}

model User {
  id              String            @id @db.Uuid
  email           String            @unique
  password_hash   String
  name            String?
  avatar_url      String?
  plan            String            @default("free")
  role            String            @default("user")
  storage_used    BigInt            @default(0)
  storage_limit   BigInt            @default(1073741824)
  created_at      DateTime          @default(now())
  updated_at      DateTime
  last_login_at   DateTime?
  bio             String?
  AIProvider      AIProvider[]
  ChatSession     ChatSession[]
  ModelParameters ModelParameters[]
  Project         Project[]
  ProjectMember   ProjectMember[]
  PromptTemplate  PromptTemplate[]
  Session         Session[]
  UserPreferences UserPreferences?
  Workspace       Workspace[]

  @@index([email])
}

model UserPreferences {
  id               String   @id @db.Uuid
  user_id          String   @unique @db.Uuid
  default_models   Json     @default("{}")
  last_used_models Json     @default("{}")
  model_parameters Json     @default("{}")
  created_at       DateTime @default(now())
  updated_at       DateTime
  User             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model Video {
  id         String   @id @db.Uuid
  project_id String   @db.Uuid
  shot_id    String?  @unique @db.Uuid
  url        String
  duration   Int
  width      Int?
  height     Int?
  format     String?
  file_size  BigInt?
  status     String   @default("processing")
  ai_model   String?
  created_at DateTime @default(now())
  Project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  Shot       Shot?    @relation(fields: [shot_id], references: [id])

  @@index([project_id])
  @@index([shot_id])
}

model VideoMergeTask {
  id            String    @id @db.Uuid
  project_id    String    @db.Uuid
  video_ids     String[]
  output_url    String?
  status        String    @default("pending")
  error_message String?
  created_at    DateTime  @default(now())
  completed_at  DateTime?
  Project       Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
}

model VideoTutorial {
  id                String   @id @db.Uuid
  title             String
  description       String
  category          String
  level             String
  duration          Int
  video_url         String
  thumbnail_url     String?
  chapters          Json     @default("[]")
  tags              String[] @default([])
  prerequisites     String[] @default([])
  related_tutorials String[] @default([])
  views             Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime

  @@index([category])
  @@index([level])
}

model VisualPrompt {
  id         String   @id @db.Uuid
  project_id String   @db.Uuid
  shot_id    String?  @db.Uuid
  prompt     String
  type       String   @default("general")
  style      String?
  parameters Json?    @default("{}")
  result     String?
  status     String   @default("pending")
  created_at DateTime @default(now())
  updated_at DateTime

  @@index([project_id])
  @@index([shot_id])
}

model Wardrobe {
  id              String    @id @db.Uuid
  character_id    String    @db.Uuid
  name            String
  description     String?
  reference_image String?
  created_at      DateTime  @default(now())
  Character       Character @relation(fields: [character_id], references: [id], onDelete: Cascade)

  @@index([character_id])
}

model WorkflowExecution {
  id              String    @id @db.Uuid
  workflow_id     String
  project_id      String    @db.Uuid
  user_id         String    @db.Uuid
  status          String    @default("pending")
  current_step_id String?
  progress        Float     @default(0)
  data            Json      @default("{}")
  metadata        Json?
  error           String?
  started_at      DateTime?
  completed_at    DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime

  @@index([project_id])
  @@index([status])
  @@index([user_id])
}

model WorkflowTemplate {
  id                 String   @id @db.Uuid
  name               String
  description        String?
  category           String
  steps              Json     @default("[]")
  estimated_duration Int      @default(0)
  tags               String[] @default([])
  is_public          Boolean  @default(false)
  created_at         DateTime @default(now())
  updated_at         DateTime

  @@index([category])
}

model LoginAttempt {
  id            String    @id @db.Uuid
  identifier    String
  ip            String
  attempts      Int
  locked_until  DateTime?
  first_attempt DateTime
  created_at    DateTime  @default(now())

  @@index([identifier])
  @@index([ip])
}

model ShotAlternative {
  id             String   @id @db.Uuid
  shot_id        String   @db.Uuid
  video_url      String
  is_recommended Boolean  @default(false)
  version        Int      @default(1)
  metadata       Json?    @default("{}")
  created_at     DateTime @default(now())

  Shot Shot @relation(fields: [shot_id], references: [id], onDelete: Cascade)

  @@index([shot_id])
  @@index([shot_id, is_recommended])
}

model ShotDraft {
  id         String   @id @db.Uuid
  shot_id    String?  @db.Uuid
  episode_id String   @db.Uuid
  scene_id   String?
  draft_data Json     @default("{}")
  created_at DateTime @default(now())
  updated_at DateTime

  Episode Episode @relation(fields: [episode_id], references: [id], onDelete: Cascade)
  Shot    Shot?   @relation(fields: [shot_id], references: [id], onDelete: Cascade)

  @@index([episode_id])
  @@index([shot_id])
}

enum AgentType {
  storyline
  outline
  director
  segment
  shot
  production
}

enum ContentType {
  script
  novel
  text
  image
  video
  audio
  storyline
  outline
}

enum MemberRole {
  owner
  editor
  viewer
}

enum ProjectType {
  script
  novel
  mixed
}

enum TaskStatus {
  pending
  processing
  completed
  failed
}

model AudioTrack {
  id         String   @id @db.Uuid
  project_id String   @db.Uuid
  shot_id    String?  @db.Uuid
  episode_id String?  @db.Uuid
  type       String
  url        String
  duration   Int
  speaker    String?
  voice_id   String?
  emotion    String?
  text       String?
  start_time Int?
  volume     Float    @default(1.0)
  status     String   @default("pending")
  created_at DateTime @default(now())
  updated_at DateTime
  Project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([shot_id])
  @@index([episode_id])
  @@index([type])
}

model Subtitle {
  id         String   @id @db.Uuid
  project_id String   @db.Uuid
  episode_id String   @db.Uuid
  entries    Json     @default("[]")
  format     String   @default("srt")
  language   String   @default("zh-CN")
  style      Json?
  created_at DateTime @default(now())
  updated_at DateTime
  Project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([episode_id])
}

model TimelineProject {
  id         String   @id @db.Uuid
  project_id String   @db.Uuid
  episode_id String   @db.Uuid
  tracks     Json     @default("[]")
  duration   Int      @default(0)
  fps        Int      @default(30)
  resolution String   @default("1080x1920")
  output_url String?
  status     String   @default("draft")
  created_at DateTime @default(now())
  updated_at DateTime
  Project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([episode_id])
}

model VoiceProfile {
  id           String   @id @db.Uuid
  project_id   String   @db.Uuid
  character_id String?  @db.Uuid
  name         String
  provider     String
  voice_id     String
  sample_url   String?
  language     String   @default("zh-CN")
  gender       String?
  style        String?
  created_at   DateTime @default(now())
  Project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([character_id])
}

model ProductionTask {
  id           String    @id @db.Uuid
  project_id   String    @db.Uuid
  episode_id   String?   @db.Uuid
  type         String
  config       Json      @default("{}")
  progress     Float     @default(0)
  current_step String?
  total_steps  Int?
  status       String    @default("pending")
  error_log    Json?
  output_url   String?
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime
  Project      Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([episode_id])
  @@index([status])
}

model Workspace {
  id         String       @id @db.Uuid
  user_id    String       @db.Uuid
  name       String       @default("默认工作台")
  config     Json         @default("{}")
  snapshot   Json?
  created_at DateTime     @default(now())
  updated_at DateTime
  User       User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  CanvasNode CanvasNode[]
  CanvasEdge CanvasEdge[]

  @@index([user_id])
}

model CanvasNode {
  id          String    @id @db.Uuid
  workspace_id String   @db.Uuid
  type        String
  position_x  Float    @default(0)
  position_y  Float    @default(0)
  config      Json     @default("{}")
  content     Json?
  output_url  String?
  history     Json     @default("[]")
  labels      String[] @default([])
  is_starred  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime
  Workspace   Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
}

model CanvasEdge {
  id           String    @id @db.Uuid
  workspace_id String   @db.Uuid
  source_node_id String @db.Uuid
  target_node_id String @db.Uuid
  created_at   DateTime @default(now())
  Workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
}
