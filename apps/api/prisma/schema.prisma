generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  avatarUrl     String?   @map("avatar_url")
  bio           String?
  plan          String    @default("free")
  role          String    @default("user") @map("role")
  storageUsed   BigInt     @default(0) @map("storage_used")
  storageLimit  BigInt     @default(1073741824) @map("storage_limit")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  lastLoginAt   DateTime?  @map("last_login_at")
  
  projects      Project[]  @relation("ProjectOwner")
  members       ProjectMember[]
  sessions      Session[]
  aiProviders   AIProvider[]
  preferences   UserPreferences?
  modelParameters ModelParameters[]
  promptTemplates PromptTemplate[]
  chatSessions  ChatSession[]
  
  @@index([email])
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Project {
  id          String           @id @default(uuid()) @db.Uuid
  ownerId    String           @map("owner_id") @db.Uuid
  name        String
  description String?
  type        ProjectType      @default(script)
  status      String           @default("draft")
  settings    Json             @default("{}")
  thumbnailUrl String?          @map("thumbnail_url")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  owner       User             @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     ProjectMember[]
  contents    Content[]
  storylines  Storyline[]
  outlines    Outline[]
  characters  Character[]
  scenes      Scene[]
  shots       Shot[]
  agentTasks  AgentTask[]
  videos      Video[]
  videoMergeTasks VideoMergeTask[]
  scripts     Script[]
  novels      Novel[]
  documents   Document[]
  promptTemplates PromptTemplate[]
  chatSessions ChatSession[]
}

model ProjectMember {
  projectId String @map("project_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid
  role      MemberRole @default(viewer)
  joinedAt  DateTime @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model Content {
  id             String      @id @default(uuid()) @db.Uuid
  projectId      String      @map("project_id") @db.Uuid
  type           ContentType
  rawText        String      @map("raw_text")
  structuredData Json?       @map("structured_data")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outlines      Outline[]
  agentTasks    AgentTask[]
  storylines    Storyline[] @relation("ContentStoryline")
}

model Storyline {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  contentId   String?  @map("content_id") @db.Uuid
  story       String   @map("story")
  aiModel     String?  @map("ai_model")
  agentTaskId String?  @map("agent_task_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content     Content? @relation("ContentStoryline", fields: [contentId], references: [id], onDelete: SetNull)
  outlines    Outline[]

  @@index([projectId])
  @@index([contentId])
}

model Outline {
  id           String     @id @default(uuid()) @db.Uuid
  projectId    String     @map("project_id") @db.Uuid
  contentId    String?    @map("content_id") @db.Uuid
  storylineId  String?    @map("storyline_id") @db.Uuid
  episodes     Json       @default("[]")
  agentTaskId  String?    @map("agent_task_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content     Content?   @relation(fields: [contentId], references: [id], onDelete: SetNull)
  storyline   Storyline? @relation(fields: [storylineId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([contentId])
  @@index([storylineId])
}

model Character {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  name             String
  age              Int?
  gender           String?
  appearance       String
  referenceImages  String[] @default([]) @map("reference_images")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wardrobes Wardrobe[]
  shots     Shot[]

  @@index([projectId])
}

model Wardrobe {
  id            String   @id @default(uuid()) @db.Uuid
  characterId   String   @map("character_id") @db.Uuid
  name          String
  description   String?
  referenceImage String?  @map("reference_image")
  createdAt     DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
}

model Scene {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  scriptId         String?  @map("script_id") @db.Uuid
  location         String
  time             String
  atmosphere       String?
  referenceImages  String[] @default([]) @map("reference_images")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  script    Script?  @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  shots     Shot[]

  @@index([projectId])
  @@index([scriptId])
}

model Shot {
  id              String          @id @default(uuid()) @db.Uuid
  projectId       String          @map("project_id") @db.Uuid
  sceneId         String?         @map("scene_id") @db.Uuid
  characterId    String?         @map("character_id") @db.Uuid
  chapterNumber   Int?            @map("chapter_number")
  episodeNumber   Int?            @map("episode_number")
  segmentId       Int?            @map("segment_id")
  cellId          Int?            @map("cell_id")
  actionSummary   String          @map("action_summary")
  cameraMovement String?         @map("camera_movement")
  startPrompt   String?         @map("start_prompt")
  endPrompt     String?         @map("end_prompt")
  startImageUrl String?         @map("start_image_url")
  endImageUrl   String?         @map("end_image_url")
  videoUrl       String?         @map("video_url")
  duration       Int             @default(8)
  aspectRatio   String          @default("16:9") @map("aspect_ratio")
  visualStyle   String?         @map("visual_style")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scene         Scene?          @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  character     Character?      @relation(fields: [characterId], references: [id], onDelete: SetNull)
  panels        NineGridPanel[]
  video         Video?

  @@index([projectId])
  @@index([sceneId])
  @@index([characterId])
}

model NineGridPanel {
  id        String   @id @default(uuid()) @db.Uuid
  shotId    String   @map("shot_id") @db.Uuid
  position  Int
  prompt    String
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  shot Shot @relation(fields: [shotId], references: [id], onDelete: Cascade)

  @@index([shotId])
  @@index([shotId, position])
}

model AgentTask {
  id           String     @id @default(uuid()) @db.Uuid
  projectId    String     @map("project_id") @db.Uuid
  contentId    String?    @map("content_id") @db.Uuid
  agentType    AgentType  @map("agent_type")
  input        Json
  output       Json?
  aiModel      String?    @map("ai_model")
  status       TaskStatus @default(pending)
  errorMessage String?    @map("error_message")
  createdAt    DateTime   @default(now()) @map("created_at")
  startedAt    DateTime?  @map("started_at")
  completedAt  DateTime?  @map("completed_at")

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content     Content?    @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([contentId])
}

model Video {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  shotId      String?  @unique @map("shot_id") @db.Uuid
  url         String
  duration    Int
  width       Int?
  height      Int?
  format      String?
  fileSize    BigInt?  @map("file_size")
  status      String   @default("processing")
  aiModel     String?  @map("ai_model")
  createdAt    DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shot    Shot?   @relation(fields: [shotId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([shotId])
}

model PromptTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  projectId    String?  @map("project_id") @db.Uuid
  code         String   @unique
  name         String
  type         String   @default("general")
  category     String?
  defaultValue String   @map("default_value")
  customValue  String?  @map("custom_value")
  parentCode   String?  @map("parent_code")
  description  String?
  variables    Json     @default("[]")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user    User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([type])
  @@index([category])
}

model ChatSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String?  @map("project_id") @db.Uuid
  title     String?
  messages  Json     @default("[]")
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}

model UserPreferences {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  defaultModels   Json     @default("{}") @map("default_models")
  lastUsedModels  Json     @default("{}") @map("last_used_models")
  modelParameters Json     @default("{}") @map("model_parameters")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ModelParameters {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  contentType ContentType @map("content_type")
  parameters  Json        @default("{}")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType])
  @@index([userId, contentType])
}

model ConfigurationHistory {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  changeType      String   @map("change_type")
  changeDetails   Json     @map("change_details")
  previousValue   Json?    @map("previous_value")
  newValue        Json     @map("new_value")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, createdAt])
}

model VideoMergeTask {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  videoIds   String[] @map("video_ids")
  outputUrl   String?  @map("output_url")
  status      String   @default("pending")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  completedAt  DateTime?  @map("completed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AIProvider {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  type      String
  apiKey    String      @map("api_key")
  baseUrl   String?     @map("base_url")
  enabled   Boolean     @default(true)
  models    AIProviderModel[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIProviderModel {
  id          String   @id @default(uuid()) @db.Uuid
  providerId  String   @map("ai_provider_id") @db.Uuid
  name        String
  types       String[]
  description String?
  capabilities String[]
  isAssistantDefault Boolean @default(false) @map("is_assistant_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  provider   AIProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  action      String
  resource    String
  resourceId  String?  @map("resource_id")
  metadata    Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  success     Boolean  @default(true)
  errorMessage String?  @map("error_message")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([resource])
  @@index([resourceId])
  @@index([createdAt])
  @@index([action])
}

model Script {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenes  Scene[]

  @@index([projectId])
}

model Novel {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapters Chapter[]

  @@index([projectId])
}

model Chapter {
  id        String   @id @default(uuid()) @db.Uuid
  novelId   String   @map("novel_id") @db.Uuid
  title     String
  content   String
  order     Int       @default(0)

  novel   Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([novelId])
  @@index([order])
}

model Document {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  title       String
  content     String
  type        String   @default("general")
  status      String   @default("draft")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
  @@index([status])
}

enum ProjectType {
  script
  novel
  mixed
}

enum ContentType {
  text
  image
  video
  audio
  script
  novel
  storyline
  outline
}

enum MemberRole {
  owner
  editor
  viewer
}

enum AgentType {
  storyline
  outline
  director
  segment
  shot
}

enum TaskStatus {
  pending
  processing
  completed
  failed
}

model QualityReport {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  type        String
  targetId    String   @map("target_id")
  score       String
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@index([targetId])
}

model WorkflowExecution {
  id            String    @id @default(uuid()) @db.Uuid
  workflowId    String    @map("workflow_id")
  projectId     String    @map("project_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  status        String    @default("pending")
  currentStepId String?   @map("current_step_id")
  progress      Float     @default(0)
  data          Json      @default("{}")
  metadata      Json?     @map("metadata")
  error         String?
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([userId])
  @@index([status])
}

model WorkflowTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  category    String
  steps       Json     @default("[]")
  estimatedDuration Int @default(0) @map("estimated_duration")
  tags        String[] @default([])
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
}

model VideoTutorial {
  id             String   @id @default(uuid()) @db.Uuid
  title          String
  description    String
  category       String
  level          String
  duration       Int
  videoUrl       String   @map("video_url")
  thumbnailUrl   String?  @map("thumbnail_url")
  chapters       Json     @default("[]")
  tags           String[] @default([])
  prerequisites  String[] @default([])
  relatedTutorials String[] @default([]) @map("related_tutorials")
  views          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([level])
}

model TutorialProgress {
  id             String    @id @default(uuid()) @db.Uuid
  tutorialId     String    @map("tutorial_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  progress       Float     @default(0)
  completed      Boolean   @default(false)
  watchedDuration Int      @default(0) @map("watched_duration")
  lastWatchedAt  DateTime  @default(now()) @map("last_watched_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([tutorialId, userId])
  @@index([userId])
}

model TutorialRating {
  id          String   @id @default(uuid()) @db.Uuid
  tutorialId  String   @map("tutorial_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  rating      Int
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([tutorialId, userId])
  @@index([tutorialId])
}

model AlertRule {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  metric      String
  condition   String
  threshold   Float
  severity    String
  enabled     Boolean  @default(true)
  channels    String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([metric])
  @@index([enabled])
}

model AlertRecord {
  id          String   @id @default(uuid()) @db.Uuid
  ruleId      String   @map("rule_id") @db.Uuid
  severity    String
  message     String
  channels    String[] @default([])
  acknowledged Boolean @default(false) @map("acknowledged")
  acknowledgedAt DateTime? @map("acknowledged_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([ruleId])
  @@index([severity])
  @@index([createdAt])
}

model Metrics {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  value     Float
  unit      String?
  timestamp DateTime @default(now()) @map("timestamp")

  @@index([name])
  @@index([timestamp])
}

model RenderTask {
  id          String    @id @default(uuid()) @db.Uuid
  type        String
  status      String    @default("pending")
  params      Json      @default("{}")
  projectId   String    @map("project_id") @db.Uuid
  priority    Int       @default(5)
  progress    Float     @default(0)
  error       String?
  logs        Json?     @default("[]")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([status])
  @@index([type])
}

model Backup {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  backupId    String   @map("backup_id") @unique
  description String?
  size        BigInt?
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([createdAt])
}

model BackupSchedule {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @map("project_id") @db.Uuid
  frequency     String
  time          String
  includeAssets Boolean   @default(true) @map("include_assets")
  retentionDays Int       @default(30) @map("retention_days")
  enabled       Boolean   @default(true)
  lastRun       DateTime? @map("last_run")
  nextRun       DateTime? @map("next_run")
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([enabled])
}

model MigrationLog {
  id          String   @id @default(uuid()) @db.Uuid
  source      String
  userId      String   @map("user_id") @db.Uuid
  result      Json     @map("result")
  timestamp   DateTime @default(now()) @map("timestamp")
  status      String   @default("pending")

  @@index([userId])
  @@index([source])
  @@index([timestamp])
}

model Plugin {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  version     String
  description String?
  entryPoint  String   @map("entry_point")
  permissions String[] @default([])
  settings    Json?    @default("{}")
  manifest    Json     @map("manifest")
  isPublic    Boolean  @default(false) @map("is_public")
  status      String   @default("pending")
  installations Int   @default(0)
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([isPublic])
}

model ProjectPlugin {
  id          String   @id @default(uuid()) @db.Uuid
  pluginId    String   @map("plugin_id") @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  installedBy String   @map("installed_by") @db.Uuid
  settings    Json     @default("{}")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([pluginId, projectId])
  @@index([projectId])
}

model ProjectTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  category    String
  config      Json     @default("{}")
  isPublic    Boolean  @default(false) @map("is_public")
  usageCount  Int      @default(0) @map("usage_count")
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([createdBy])
}

model Asset {
  id        String   @id @default(uuid()) @db.Uuid
  type      String
  url       String
  projectId String   @map("project_id") @db.Uuid
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([type])
}

model ProjectVersion {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String?
  description String?
  tags        String[] @default([])
  snapshot    Json     @map("snapshot")
  parentId    String?  @map("parent_id") @db.Uuid
  version     Int      @default(1)
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([parentId])
  @@index([createdBy])
}

model SceneConcept {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String
  description String?
  location    String
  timeOfDay   String?  @map("time_of_day")
  atmosphere  String?
  referenceImages String[] @default([]) @map("reference_images")
  aiPrompt    String?  @map("ai_prompt")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([projectId])
}

model ScriptAnalysis {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  content     String
  summary     String?
  themes      String[] @default([])
  characters  Json     @default("[]")
  plotPoints  Json     @default("[]")
  sentiment   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([projectId])
}

model VisualPrompt {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  shotId      String?  @map("shot_id") @db.Uuid
  prompt      String
  type        String   @default("general")
  style       String?
  parameters  Json?    @default("{}")
  result      String?
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([shotId])
}
