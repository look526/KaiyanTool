    "bull": "^4.11.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "jsonrepair": "^3.13.3",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
